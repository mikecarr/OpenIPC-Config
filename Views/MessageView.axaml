<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:OpenIPC_Config.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OpenIPC_Config.Views.MessageView"
             x:DataType="viewModels:MessageViewModel"
             d:DataContext="{d:DesignInstance Type=viewModels:MessageViewModel}">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/Styles.axaml" />
    </UserControl.Styles>
    
    <StackPanel>
        <ScrollViewer>
            <TextBlock Text="{Binding MessageText}" TextWrapping="Wrap" />
        </ScrollViewer>
    </StackPanel>
</UserControl>